# ═══════════════════════════════════════════════════════════════
# ZKS Białogard — Manager · zmienne na Vercel
# Vercel → Project → Settings → Environment Variables
# Dodaj każdą zmienną dla: Production, Preview, Development
# Wartości skopiuj z lokalnego pliku .env.local (NIE commituj .env.local!)
# ═══════════════════════════════════════════════════════════════

# ─── Supabase (wymagane) ───
NEXT_PUBLIC_SUPABASE_URL=https://ubvgiglzteunqgxmezkt.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ─── Firebase (opcjonalne — domyślna konfiguracja jest w kodzie) ───
# NEXT_PUBLIC_FIREBASE_API_KEY=

# ─── SMS — SMSAPI (https://www.smsapi.pl/) ───
# 1. Załóż konto → doładuj środki
# 2. Tokeny API (OAuth) → skopiuj token z uprawnieniem wysyłki SMS
# 3. Vercel → SMSAPI_TOKEN=...
# 4. Vercel → SMSAPI_FROM=ZKS  (pole nadawcy — dodaj i zatwierdź w panelu SMSAPI)
# 5. Admin → Szablony → „Wyślij test SMS”
SMSAPI_TOKEN=
SMSAPI_FROM=ZKS

# ─── Domena publiczna (SEO + PWA + przekierowanie z vercel.app) ───
# Ustaw docelową domenę po podpięciu w Vercel → Settings → Domains
# Przykład: https://manager.zksbialogard.pl
NEXT_PUBLIC_SITE_URL=https://manager.zksbialogard.pl
NEXT_PUBLIC_APP_URL=https://manager.zksbialogard.pl

# ─── Email — opcjonalne (formularz kontaktowy na stronie /kontakt) ───
# Resend (https://resend.com/) — klucz API + zweryfikowany nadawca
RESEND_API_KEY=
EMAIL_FROM=ZKS Białogard <onboarding@resend.dev>
# Tryb testowy Resend — adres docelowy gdy EMAIL_FROM to onboarding@resend.dev
RESEND_SANDBOX_TO=
# Odbiorca wiadomości z formularza kontaktowego (domyślnie: zksbialogard@wp.pl)
CLUB_CONTACT_EMAIL=

# ─── Powiadomienia push (jak w normalnej aplikacji na telefon) ───
# Wygeneruj klucze lokalnie: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:kontakt@zksbialogard.pl

# ─── Powiadomienia (wymaga tabel w Supabase — supabase/migrations/001_notifications.sql) ───
# Po uruchomieniu SQL w Supabase działa centrum powiadomień i szablony wiadomości.
# Dodatkowo uruchom: 003_push_subscriptions.sql

# ═══════════════════════════════════════════════════════════════
# PO WDROŻENIU — ustawienia poza Vercel
# ═══════════════════════════════════════════════════════════════
#
# 1. Firebase Console → Authentication → Settings → Authorized domains
#    Dodaj: manager.zksbialogard.pl (oraz zks-wrestling.vercel.app na czas migracji)
#
# 2. Vercel → Settings → Domains → dodaj manager.zksbialogard.pl
#    Ustaw NEXT_PUBLIC_SITE_URL=https://manager.zksbialogard.pl i zrób redeploy
#
# 3. Google Search Console → dodaj domenę → wyślij sitemap:
#    https://manager.zksbialogard.pl/sitemap.xml
# ═══════════════════════════════════════════════════════════════
