# ═══════════════════════════════════════════════════════════════
# ZKS Białogard — Manager · zmienne na Vercel
# Vercel → Project → Settings → Environment Variables
# Dodaj każdą zmienną dla: Production, Preview, Development
# Wartości skopiuj z lokalnego pliku .env.local (NIE commituj .env.local!)
# ═══════════════════════════════════════════════════════════════

# ─── Supabase (wymagane) ───
NEXT_PUBLIC_SUPABASE_URL=https://ubvgiglzteunqgxmezkt.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ─── Firebase (opcjonalne — domyślna konfiguracja jest w kodzie) ───
# NEXT_PUBLIC_FIREBASE_API_KEY=

# ─── SMS — SMSAPI (https://www.smsapi.pl/) ───
SMSAPI_TOKEN=

# ─── Email — Resend (https://resend.com/) ───
# 1. Załócz konto → API Keys → skopiuj klucz
# 2. Vercel → RESEND_API_KEY=re_...
# 3. EMAIL_FROM=ZKS Białogard <onboarding@resend.dev>  (test)
#    Po weryfikacji domeny: ZKS Białogard <zksbialogard@wp.pl>
# 4. Admin → Szablony → „Wyślij test”
RESEND_API_KEY=
EMAIL_FROM=ZKS Białogard <onboarding@resend.dev>
NEXT_PUBLIC_APP_URL=https://zks-wrestling.vercel.app

# ─── Powiadomienia push (jak w normalnej aplikacji na telefon) ───
# Wygeneruj klucze lokalnie: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:kontakt@zksbialogard.pl

# ─── Powiadomienia (wymaga tabel w Supabase — supabase/migrations/001_notifications.sql) ───
# Po uruchomieniu SQL w Supabase działa centrum powiadomień i szablony wiadomości.
# Dodatkowo uruchom: 003_push_subscriptions.sql

# ═══════════════════════════════════════════════════════════════
# PO WDROŻENIU — ustawienia poza Vercel
# ═══════════════════════════════════════════════════════════════
#
# 1. Firebase Console → Authentication → Settings → Authorized domains
#    Dodaj: twoja-apka.vercel.app  oraz własną domenę (jeśli masz)
#
# 2. Supabase → Authentication → URL Configuration (jeśli używasz Supabase Auth)
#
# 3. Resend → zweryfikuj domenę nadawcy przed produkcyjnym emailem
#
# 4. Po deploy: otwórz https://twoja-apka.vercel.app na telefonie
#    → Zainstaluj aplikację (PWA) z przeglądarki
# ═══════════════════════════════════════════════════════════════
