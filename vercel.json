{
  "crons": [
    {
      "path": "/api/cron/reminders",
      "schedule": "0 16 * * *"
    },
    {
      "path": "/api/cron/training-reminders/12",
      "schedule": "0 10 * * *"
    },
    {
      "path": "/api/cron/training-reminders/15",
      "schedule": "0 13 * * *"
    },
    {
      "path": "/api/cron/app-update-notify",
      "schedule": "0 5 * * *"
    },
    {
      "path": "/api/cron/facebook-results",
      "schedule": "0 6 * * *"
    }
  ],
  "headers": [
    {
      "source": "/sw.js",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        },
        {
          "key": "Service-Worker-Allowed",
          "value": "/"
        }
      ]
    },
    {
      "source": "/manifest.json",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=86400"
        }
      ]
    }
  ]
}
